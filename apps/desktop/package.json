{
  "name": "@race-engineer/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc --noEmit -p electron/tsconfig.json",
    "dev": "echo \"[dev] Install the Electron shell first: pnpm --filter @race-engineer/desktop add -D electron — then: pnpm --filter @race-engineer/desktop dev:electron\"",
    "dev:electron": "electron electron/main.ts"
  },
  "dependencies": {
    "@race-engineer/adapter-sim-replay": "workspace:*",
    "@race-engineer/core": "workspace:*",
    "@race-engineer/engineer-core": "workspace:*"
  }
}
